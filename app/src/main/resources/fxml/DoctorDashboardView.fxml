<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.DoctorDashboardController" 
      prefHeight="768.0" prefWidth="1024.0" styleClass="doctor-dashboard" stylesheets="/css/doctor-dashboard.css">
    
    <!-- Header Section -->
    <HBox styleClass="header-section" alignment="CENTER_LEFT" spacing="20.0">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
        </padding>
        <children>
            <Label fx:id="welcomeBanner" text="Selamat datang, DR. Doctor User" styleClass="welcome-banner" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" styleClass="logout-button" />
        </children>
    </HBox>
    
    <!-- Navigation Tabs -->
    <HBox styleClass="nav-tabs" spacing="10.0" alignment="CENTER_LEFT">
        <children>
            <Button fx:id="appointmentsTab" text="Appointments" onAction="#handleAppointmentsTab" styleClass="nav-tab" />
            <Button fx:id="patientsTab" text="Patients" onAction="#handlePatientsTab" styleClass="nav-tab" />
            <Button fx:id="scheduleTab" text="My Schedule" onAction="#handleScheduleTab" styleClass="nav-tab" />
            <Button fx:id="profileTab" text="Profile" onAction="#handleProfileTab" styleClass="nav-tab" />
        </children>
    </HBox>
    
    <!-- Main Content Area with StackPane for tab switching -->
    <StackPane VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
        </padding>
        
        <!-- Appointments Tab Content -->
        <HBox fx:id="appointmentsTabContent" spacing="20.0" visible="true">
            <!-- Left Panel - Date Selection & Appointments -->
            <VBox spacing="15.0" prefWidth="400.0">
                <children>
                    <!-- Date Selection Section -->
                    <VBox spacing="10.0" styleClass="date-section">
                        <children>
                            <Label text="Appointment Date Picker" styleClass="section-header" />
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <children>
                                    <DatePicker fx:id="appointmentDatePicker" onAction="#handleDateChange" promptText="Select date" />
                                    <Button fx:id="viewAppointmentsButton" text="View Appointments" onAction="#handleViewAppointments" styleClass="view-button" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                    
                    <!-- Today's Appointments Section -->
                    <VBox spacing="10.0" styleClass="appointments-section" VBox.vgrow="ALWAYS">
                        <children>
                            <Label text="Today's Appointments" styleClass="section-header" />
                            <ScrollPane fx:id="appointmentsScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="appointments-scroll">
                                <content>
                                    <VBox fx:id="appointmentsContainer" spacing="12.0">
                                        <!-- Dynamic appointment cards will be added here -->
                                    </VBox>
                                </content>
                            </ScrollPane>
                        </children>
                    </VBox>
                </children>
            </VBox>
            
            <!-- Right Panel - Statistics & Quick Actions -->
            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                <children>
                    <!-- Statistics Cards -->
                    <GridPane hgap="15.0" vgap="15.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" />
                            <ColumnConstraints hgrow="SOMETIMES" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                        </rowConstraints>
                        
                        <!-- Today's Patients -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <children>
                                <Label text="Today's Patients" styleClass="stat-label" />
                                <Label fx:id="todayPatientsCount" text="12" styleClass="stat-number" />
                            </children>
                        </VBox>
                        
                        <!-- Pending Appointments -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <children>
                                <Label text="Pending" styleClass="stat-label" />
                                <Label fx:id="pendingCount" text="5" styleClass="stat-number" />
                            </children>
                        </VBox>
                        
                        <!-- Completed Today -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <children>
                                <Label text="Completed Today" styleClass="stat-label" />
                                <Label fx:id="completedCount" text="8" styleClass="stat-number" />
                            </children>
                        </VBox>
                        
                        <!-- Total Patients -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <children>
                                <Label text="Total Patients" styleClass="stat-label" />
                                <Label fx:id="totalPatientsCount" text="156" styleClass="stat-number" />
                            </children>
                        </VBox>
                    </GridPane>
                    
                    <!-- Quick Actions -->
                    <VBox spacing="10.0" styleClass="quick-actions">
                        <children>
                            <Label text="Quick Actions" styleClass="section-header" />
                            <VBox spacing="8.0">
                                <children>
                                    <Button fx:id="viewReportsButton" text="View Reports" onAction="#handleViewReports" styleClass="action-button" maxWidth="Infinity" />
                                    <Button fx:id="prescriptionsButton" text="Manage Prescriptions" onAction="#handlePrescriptions" styleClass="action-button" maxWidth="Infinity" />
                                    <Button fx:id="settingsButton" text="Settings" onAction="#handleSettings" styleClass="action-button" maxWidth="Infinity" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </HBox>
        
        <!-- Patients Tab Content -->
        <VBox fx:id="patientsTabContent" spacing="20.0" styleClass="tab-content" visible="false">
            <children>
                <Label text="All Patients" styleClass="section-header" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="appointments-scroll">
                    <content>
                        <VBox fx:id="patientsContainer" spacing="15.0">
                            <!-- Dynamic patient list will be added here -->
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
        
        <!-- Schedule Tab Content -->
        <VBox fx:id="scheduleTabContent" spacing="20.0" styleClass="tab-content" visible="false">
            <children>
                <Label text="My Schedule" styleClass="section-header" />
                
                <!-- Calendar Navigation -->
                <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="date-section">
                    <children>
                        <Button fx:id="prevWeekButton" text="◀ Previous Week" onAction="#handlePrevWeek" styleClass="view-button" />
                        <Label fx:id="currentWeekLabel" text="Week of January 15, 2024" styleClass="patient-name" />
                        <Button fx:id="nextWeekButton" text="Next Week ▶" onAction="#handleNextWeek" styleClass="view-button" />
                    </children>
                </HBox>
                
                <!-- Weekly Calendar -->
                <GridPane fx:id="weeklyCalendar" hgap="5.0" vgap="5.0" VBox.vgrow="ALWAYS" styleClass="appointments-section">
                    <!-- Calendar grid will be populated dynamically -->
                </GridPane>
            </children>
        </VBox>
        
        <!-- Profile Tab Content -->
        <VBox fx:id="profileTabContent" spacing="20.0" styleClass="tab-content" visible="false">
            <children>
                <Label text="Doctor Profile" styleClass="section-header" />
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="appointments-scroll">
                    <content>
                        <VBox fx:id="profileContainer" spacing="20.0">
                            <!-- Profile information will be added here -->
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </StackPane>
</VBox>