<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AdminController" prefHeight="700.0" prefWidth="1200.0" styleClass="admin-dashboard" stylesheets="/css/admin-dashboard-style.css">
    <top>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" styleClass="admin-header">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <StackPane style="-fx-min-width: 32; -fx-min-height: 32;">
                            <children>
                                <SVGPath content="M12 2L13.09 8.26L22 9L13.09 9.74L12 16L10.91 9.74L2 9L10.91 8.26L12 2Z" styleClass="admin-logo-icon" />
                            </children>
                        </StackPane>
                        <Label text="Admin Dashboard" styleClass="admin-logo-text" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button text="Admin Panel" styleClass="admin-nav-button" />
                        <Button text="Settings" styleClass="admin-nav-button" />
                        <Button text="Logout" fx:id="logoutButton" styleClass="admin-nav-button-secondary" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="admin-scroll-pane">
            <content>
                <VBox spacing="30.0" styleClass="admin-content">
                    <padding>
                        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                    </padding>
                    
                    <!-- Statistics Cards -->
                    <VBox spacing="20.0">
                        <children>
                            <Label text="Overview" styleClass="admin-section-title" />
                            <HBox spacing="25.0" alignment="CENTER">
                                <children>
                                    <!-- Products Card -->
                                    <VBox styleClass="admin-stat-card" alignment="CENTER" spacing="10.0" prefWidth="220" prefHeight="140">
                                        <children>
                                            <StackPane styleClass="admin-stat-icon-container">
                                                <children>
                                                    <SVGPath content="M7 4V2C7 1.45 7.45 1 8 1H16C16.55 1 17 1.45 17 2V4H20V6H19V19C19 20.1 18.1 21 17 21H7C5.9 21 5 20.1 5 19V6H4V4H7ZM9 3V4H15V3H9ZM7 6V19H17V6H7Z" styleClass="admin-stat-icon" />
                                                </children>
                                            </StackPane>
                                            <Label text="Total Products" styleClass="admin-stat-label" />
                                            <Label fx:id="totalProductsLabel" text="0" styleClass="admin-stat-value" />
                                        </children>
                                    </VBox>
                                    
                                    <!-- Doctors Card -->
                                    <VBox styleClass="admin-stat-card" alignment="CENTER" spacing="10.0" prefWidth="220" prefHeight="140">
                                        <children>
                                            <StackPane styleClass="admin-stat-icon-container">
                                                <children>
                                                    <SVGPath content="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2ZM21 9V7L15 7C14.45 7 14 7.45 14 8V10C14 10.55 14.45 11 15 11H18L19 12L18 13H15C14.45 13 14 13.45 14 14V16C14 16.55 14.45 17 15 17H21V15H16V14H19L21 12V10H16V9H21Z" styleClass="admin-stat-icon" />
                                                </children>
                                            </StackPane>
                                            <Label text="Total Doctors" styleClass="admin-stat-label" />
                                            <Label fx:id="totalDoctorsLabel" text="0" styleClass="admin-stat-value" />
                                        </children>
                                    </VBox>
                                    
                                    <!-- Orders Card -->
                                    <VBox styleClass="admin-stat-card" alignment="CENTER" spacing="10.0" prefWidth="220" prefHeight="140">
                                        <children>
                                            <StackPane styleClass="admin-stat-icon-container">
                                                <children>
                                                    <SVGPath content="M7 4V2C7 1.45 7.45 1 8 1H16C16.55 1 17 1.45 17 2V4H20V6H19V19C19 20.1 18.1 21 17 21H7C5.9 21 5 20.1 5 19V6H4V4H7Z" styleClass="admin-stat-icon" />
                                                </children>
                                            </StackPane>
                                            <Label text="Total Orders" styleClass="admin-stat-label" />
                                            <Label fx:id="totalOrdersLabel" text="0" styleClass="admin-stat-value" />
                                        </children>
                                    </VBox>
                                    
                                    <!-- Revenue Card -->
                                    <VBox styleClass="admin-stat-card" alignment="CENTER" spacing="10.0" prefWidth="220" prefHeight="140">
                                        <children>
                                            <StackPane styleClass="admin-stat-icon-container">
                                                <children>
                                                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12S6.48 22 12 22 22 17.52 22 12 17.52 2 12 2ZM13.41 18.09L13.41 20H10.59V18.09C9.59 17.79 8.79 17.21 8.21 16.41L9.92 15.19C10.27 15.73 10.74 16 11.5 16C12.26 16 12.73 15.73 13.08 15.19L14.79 16.41C14.21 17.21 13.41 17.79 12.41 18.09H13.41ZM15 13C15 14.25 13.5 15.5 12 15.5S9 14.25 9 13V12C9 10.75 10.5 9.5 12 9.5S15 10.75 15 12V13Z" styleClass="admin-stat-icon" />
                                                </children>
                                            </StackPane>
                                            <Label text="Revenue" styleClass="admin-stat-label" />
                                            <Label fx:id="totalRevenueLabel" text="Rp 0" styleClass="admin-stat-value" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                      <!-- Product Grid Section -->
                    <VBox spacing="20.0">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="15.0">
                                <children>
                                    <Label text="Product Catalog" styleClass="admin-section-title" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="addNewProductButton" text="Add New Product" styleClass="admin-button-primary" />
                      
                                </children>
                            </HBox>                            <!-- Product Cards Grid -->
                            <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="product-grid-scroll">
                                <content>
                                    <HBox fx:id="productGridContainer" spacing="20.0" alignment="CENTER_LEFT" styleClass="product-grid-container">
                                        <padding>
                                            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                                        </padding>
                                        <!-- Product cards will be dynamically loaded here -->
                                    </HBox>
                                </content>
                            </ScrollPane>
                        </children>
                    </VBox>
                    
                    <!-- Main Content Area -->
                    <VBox spacing="20.0">
                        <children>
                            <Label text="Management" styleClass="admin-section-title" />
                            
                            <!-- Product Management Card -->
                            <VBox styleClass="admin-management-card" spacing="20.0">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                                        <children>
                                            <StackPane styleClass="admin-card-icon-container">
                                                <children>
                                                    <SVGPath content="M7 4V2C7 1.45 7.45 1 8 1H16C16.55 1 17 1.45 17 2V4H20V6H19V19C19 20.1 18.1 21 17 21H7C5.9 21 5 20.1 5 19V6H4V4H7Z" styleClass="admin-card-icon" />
                                                </children>
                                            </StackPane>
                                            <VBox spacing="5.0">
                                                <children>
                                                    <Label text="Product Management" styleClass="admin-card-title" />
                                                    <Label text="Manage inventory, add new products, and update stock" styleClass="admin-card-subtitle" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
                                    
                                    <TableView fx:id="stokTable" prefHeight="300" styleClass="admin-table">
                                        <columns>
                                            <TableColumn fx:id="namaCol" text="Product Name" prefWidth="300" styleClass="admin-table-column" />
                                            <TableColumn fx:id="hargaCol" text="Price" prefWidth="200" styleClass="admin-table-column" />
                                            <TableColumn fx:id="stokCol" text="Stock" prefWidth="150" styleClass="admin-table-column" />
                                            <TableColumn fx:id="categoryCol" text="Category" prefWidth="200" styleClass="admin-table-column" />
                                        </columns>
                                    </TableView>
                                </children>
                            </VBox>
                            
                            <!-- Doctor Management Card -->
                            <VBox styleClass="admin-management-card" spacing="20.0">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                                        <children>
                                            <StackPane styleClass="admin-card-icon-container">
                                                <children>
                                                    <SVGPath content="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2Z" styleClass="admin-card-icon" />
                                                </children>
                                            </StackPane>
                                            <VBox spacing="5.0">
                                                <children>
                                                    <Label text="Doctor Management" styleClass="admin-card-title" />
                                                    <Label text="Add new doctors and manage their accounts" styleClass="admin-card-subtitle" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
                                    
                                    <HBox spacing="30.0" alignment="TOP_CENTER">
                                        <children>
                                            <!-- Add Doctor Form -->
                                            <VBox spacing="15.0" prefWidth="400" styleClass="admin-form-section">
                                                <children>
                                                    <Label text="Add New Doctor" styleClass="admin-form-title" />
                                                    <TextField fx:id="doctorNameField" promptText="Doctor Name" styleClass="admin-input-field" />
                                                    <TextField fx:id="doctorSpesialisField" promptText="Specialization" styleClass="admin-input-field" />
                                                    <PasswordField fx:id="doctorPasswordField" promptText="Password" styleClass="admin-input-field" />
                                                    <Button text="Add Doctor" fx:id="addDoctorButton" styleClass="admin-button-primary" maxWidth="Infinity" />
                                                </children>
                                            </VBox>
                                            
                                            <!-- Doctor List -->
                                            <VBox spacing="15.0" prefWidth="500" styleClass="admin-form-section">
                                                <children>
                                                    <Label text="Existing Doctors" styleClass="admin-form-title" />
                                                    <TableView fx:id="doctorTable" prefHeight="250" styleClass="admin-table">
                                                        <columns>
                                                            <TableColumn fx:id="doctorNameCol" text="Name" prefWidth="150" styleClass="admin-table-column" />
                                                            <TableColumn fx:id="doctorSpecCol" text="Specialization" prefWidth="150" styleClass="admin-table-column" />
                                                            <TableColumn fx:id="doctorEmailCol" text="Email" prefWidth="200" styleClass="admin-table-column" />
                                                        </columns>
                                                    </TableView>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                    
                    <!-- Notification Area -->
                    <Label fx:id="notificationLabel" visible="false" managed="false" styleClass="admin-notification" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
